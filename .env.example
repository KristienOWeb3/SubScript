# SubScript Smart Contract and Node Configurations
PRIVATE_KEY=0xYOUR_DEPLOYER_PRIVATE_KEY
CLI_CONFIG_SIGNING_KEY=0xYOUR_CLI_CONFIG_SIGNING_KEY
RPC_URL=https://rpc.testnet.arc.network
CONTRACT_ADDRESS=0x835A9aEd7287068778e11df9D922B3FfaC7cFc29
USDC_ADDRESS=0x3600000000000000000000000000000000000000

# PostgreSQL Database URL for Prisma Waitlist Leads
DATABASE_URL="postgresql://username:password@hostname:port/database"

# Supabase Off-chain Protocol Tracking Configurations
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
SUBSCRIPT_WEBHOOK_SECRET=your-subscript-webhook-signature-verification-secret
RESEND_API_KEY=""

# JWT Session Verification Secret
JWT_SECRET=your-jwt-session-secret-min-32-characters

# Keeper API Secret Token
KEEPER_SECRET=your-keeper-secret-token

# Upstash Redis Configuration (Distributed Rate Limiting)
UPSTASH_REDIS_REST_URL=https://your-database.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-redis-rest-token
