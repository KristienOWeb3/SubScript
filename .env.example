NEXT_PUBLIC_APP_URL=https://www.subscriptonarc.com

# Analytics
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# SEO verification tokens
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
NEXT_PUBLIC_BING_SITE_VERIFICATION=

# Rate limiting and IP bans
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
BANNED_IPS=

# Email
RESEND_API_KEY=
EMAIL_FROM=SubScript <support@subscriptonarc.com>

# API integration testing
SUBSCRIPT_API_KEY=your_api_key_here

# Web Push notifications (generate with: npx web-push generate-vapid-keys)
# The public key must also be exposed to the browser via the NEXT_PUBLIC_ copy.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_SUBJECT=mailto:support@subscriptonarc.com

# --- Server secrets (required in production; never commit real values) ---
DATABASE_URL=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUBSCRIPT_WEBHOOK_SECRET=
# Cloudflare Turnstile (bot check on signup). BOTH are REQUIRED — verification fails CLOSED, so if
# TURNSTILE_SECRET_KEY is unset every captcha-gated signup is rejected (and the widget won't render
# without the public site key). Create a widget at Cloudflare → Turnstile to get both keys.
TURNSTILE_SECRET_KEY=
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
# Keeper / cron auth. The customer-renewal cron (/api/cron/customer-billing) accepts either.
# Vercel Cron sends Authorization: Bearer ${CRON_SECRET}, so CRON_SECRET must be set for it to run.
KEEPER_SECRET=
CRON_SECRET=
# Admin wallet that signs on-chain keeper txs (executePayment, tier changes) and pays their gas.
PRIVATE_KEY=
# REQUIRED for Merchant-User actions. SubScript sponsors gas: a funded EOA just-in-time tops up
# the user's embedded wallet so gas never eats their payment principal. If this is unset (or the
# wallet is empty), subscribe / cancel / change-plan / vault-commit / execute-tx all FAIL CLOSED
# with "Gas sponsorship unavailable". Set it to a funded Arc EOA (testnet USDC for gas on testnet).
SPONSOR_PRIVATE_KEY=
# Native-USDC gas credited per sponsored action (default 0.10). Keep small; the 1% fee recoups it.
SPONSOR_GAS_TOPUP_USDC=0.10
# Server RPC used by ethers in API/cron routes. Set to the mainnet RPC when going live.
RPC_URL=https://rpc.testnet.arc.network

# --- Network selection: leave as testnet, or set to "mainnet" to go live ---
NEXT_PUBLIC_ENVIRONMENT=testnet
# Client RPC (wagmi/viem). Set to the mainnet RPC when NEXT_PUBLIC_ENVIRONMENT=mainnet.
NEXT_PUBLIC_ARC_RPC_PRIMARY=

# --- NGN bank-transfer funding ---
# Not wired yet: the /api/user/funding-intents endpoints return 503 and the deposit UI shows
# "arriving at mainnet". The card-free NGN bank-transfer rail lands with the Arc mainnet launch
# and a licensed funding partner; its config vars are reintroduced here at that point.

# --- Contract addresses: defaults are Arc TESTNET. Set these to your MAINNET addresses to go live ---
NEXT_PUBLIC_SUBSCRIPT_ROUTER_ADDRESS=
NEXT_PUBLIC_STANDARD_CONTRACT_ADDRESS=
NEXT_PUBLIC_CONFIDENTIAL_CONTRACT_ADDRESS=
NEXT_PUBLIC_PREMIUM_PAYMENT_RECIPIENT_ADDRESS=
NEXT_PUBLIC_ARC_MEMO_CONTRACT_ADDRESS=
NEXT_PUBLIC_USDC_ADDRESS=

# --- Circle developer-controlled (MPC) wallets — Phase 1 custody migration ---
# Custodial embedded wallets are moving from a single-AES-key model to Circle MPC custody.
# Provision in the Circle Console (sandbox first): enable Developer-Controlled Wallets on the API
# key, then generate + register an entity secret. Store CIRCLE_ENTITY_SECRET in a secret manager.
CIRCLE_API_KEY=
CIRCLE_ENTITY_SECRET=
# Run createArcWalletSet() once, then paste the returned id here (all wallets are created in it).
CIRCLE_ARC_WALLET_SET_ID=
# "SCA" (default — enables Gas Station sponsored USDC gas on Arc) or "EOA".
CIRCLE_WALLET_ACCOUNT_TYPE=SCA
# Arc blockchain id as Circle names it (mainnet: ARC).
CIRCLE_ARC_BLOCKCHAIN=ARC-TESTNET
