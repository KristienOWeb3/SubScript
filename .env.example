NEXT_PUBLIC_APP_URL=https://www.subscriptonarc.com

# Analytics
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# SEO verification tokens
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
NEXT_PUBLIC_BING_SITE_VERIFICATION=

# Rate limiting and IP bans
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
BANNED_IPS=

# Email
RESEND_API_KEY=
EMAIL_FROM=SubScript <support@subscriptonarc.com>

# API integration testing
SUBSCRIPT_API_KEY=your_api_key_here

# Web Push notifications (generate with: npx web-push generate-vapid-keys)
# The public key must also be exposed to the browser via the NEXT_PUBLIC_ copy.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_SUBJECT=mailto:support@subscriptonarc.com

# ----------------------------------------------------------------------------
# Network selection (testnet by default). Set to "mainnet" to go live.
# ----------------------------------------------------------------------------
NEXT_PUBLIC_ENVIRONMENT=testnet

# Arc RPC endpoints (server + client). Defaults to the public Arc RPC for the active network.
ARC_RPC_PRIMARY=
ARC_RPC_SECONDARY=
RPC_FALLBACK_URL_1=
RPC_FALLBACK_URL_2=
NEXT_PUBLIC_ARC_RPC_PRIMARY=

# Mainnet contract addresses — REQUIRED when NEXT_PUBLIC_ENVIRONMENT=mainnet.
# On mainnet these have NO testnet fallback: if unset, on-chain calls fail loudly rather than
# silently using a testnet contract. Leave blank on testnet (documented testnet defaults are used).
NEXT_PUBLIC_ROUTER_ADDRESS=
NEXT_PUBLIC_STANDARD_ADDRESS=
NEXT_PUBLIC_CONFIDENTIAL_ADDRESS=
NEXT_PUBLIC_PREMIUM_RECIPIENT_ADDRESS=
NEXT_PUBLIC_MEMO_ADDRESS=
NEXT_PUBLIC_MESSAGE_TRANSMITTER_ADDRESS=
NEXT_PUBLIC_PLATFORM_MERCHANT_ADDRESS=
NEXT_PUBLIC_USDC_ADDRESS=

# ----------------------------------------------------------------------------
# Server secrets (REQUIRED in production — never expose to the client)
# ----------------------------------------------------------------------------
# Database
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
DATABASE_URL=

# Auth / crypto — generate strong unique random values
JWT_SECRET=
OTP_SECRET=
WALLET_ENCRYPTION_KEY=

# Protocol operations
PRIVATE_KEY=                 # keeper/admin signer (sponsors gas, executes payouts/billing)
KEEPER_SECRET=               # bearer token guarding cron/keeper + internal billing routes
SUBSCRIPT_WEBHOOK_SECRET=    # HMAC secret for inbound protocol webhooks
ADMIN_API_KEY=               # guards admin endpoints (e.g. merchant verification)

# Observability
NEXT_PUBLIC_SENTRY_DSN=

# Production guard: ensure this is set to "production" in the live environment so dev auth
# fallbacks (offline OTP, sandbox codes) stay disabled.
NODE_ENV=production
