NEXT_PUBLIC_APP_URL=https://www.subscriptonarc.com

# Analytics
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# SEO verification tokens
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
NEXT_PUBLIC_BING_SITE_VERIFICATION=

# Rate limiting and IP bans
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
BANNED_IPS=

# Email
RESEND_API_KEY=
EMAIL_FROM=SubScript <support@subscriptonarc.com>

# API integration testing
SUBSCRIPT_API_KEY=your_api_key_here

# Web Push notifications (generate with: npx web-push generate-vapid-keys)
# The public key must also be exposed to the browser via the NEXT_PUBLIC_ copy.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_SUBJECT=mailto:support@subscriptonarc.com

# --- Server secrets (required in production; never commit real values) ---
DATABASE_URL=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUBSCRIPT_WEBHOOK_SECRET=
# Keeper / cron auth. The customer-renewal cron (/api/cron/customer-billing) accepts either.
# Vercel Cron sends Authorization: Bearer ${CRON_SECRET}, so CRON_SECRET must be set for it to run.
KEEPER_SECRET=
CRON_SECRET=
# DM-game timeout keeper. Trigger GET or POST /api/cron/games-timeout hourly with either
# secret above. It is intentionally not an hourly Vercel Cron so free-tier deploys stay valid.
# Admin wallet that signs on-chain keeper txs (executePayment, tier changes) and pays their gas.
PRIVATE_KEY=
# Server RPC used by ethers in API/cron routes. Set to the mainnet RPC when going live.
RPC_URL=https://rpc.testnet.arc.network

# --- Network selection: leave as testnet, or set to "mainnet" to go live ---
NEXT_PUBLIC_ENVIRONMENT=testnet
# Client RPC (wagmi/viem). Set to the mainnet RPC when NEXT_PUBLIC_ENVIRONMENT=mainnet.
NEXT_PUBLIC_ARC_RPC_PRIMARY=

# --- NGN bank-transfer funding ---
# Keep disabled in production. "sandbox" only returns deliberately fake bank details on Arc testnet.
FIAT_ONRAMP_MODE=disabled
FIAT_ONRAMP_NETWORK=arc-testnet
FIAT_ONRAMP_CHAIN_ID=5042002
FIAT_ONRAMP_MIN_NGN=1000.00
FIAT_ONRAMP_MAX_NGN=1000000.00
FIAT_ONRAMP_QUOTE_RATE_NGN_PER_USDC=1600.00
FIAT_ONRAMP_QUOTE_TTL_SECONDS=900

# --- Peer games ---
# "sandbox" is fully simulated and never touches a wallet. "testnet" requires both addresses.
DM_GAMES_MODE=disabled
DM_GAMES_NETWORK=arc-testnet
DM_GAMES_CHAIN_ID=5042002
DM_GAMES_TREASURY_ADDRESS=
NEXT_PUBLIC_DM_GAME_ESCROW_ADDRESS=
DM_GAMES_REFEREE_ADDRESS=
# Private key whose wallet matches DM_GAMES_REFEREE_ADDRESS; used only for testnet result signatures.
KEEPER_PRIVATE_KEY=
DM_GAMES_MIN_STAKE_USDC=1
DM_GAMES_MAX_STAKE_USDC=100

# --- Contract addresses: defaults are Arc TESTNET. Set these to your MAINNET addresses to go live ---
NEXT_PUBLIC_SUBSCRIPT_ROUTER_ADDRESS=
NEXT_PUBLIC_STANDARD_CONTRACT_ADDRESS=
NEXT_PUBLIC_CONFIDENTIAL_CONTRACT_ADDRESS=
NEXT_PUBLIC_PREMIUM_PAYMENT_RECIPIENT_ADDRESS=
NEXT_PUBLIC_ARC_MEMO_CONTRACT_ADDRESS=
NEXT_PUBLIC_USDC_ADDRESS=
