{
    "name": "@subscriptonarc/app",
    "version": "1.2.3",
    "private": true,
    "description": "Programmable USDC payments for modern commerce — subscriptions, checkout, usage billing, and peer payments settled on Arc.",
    "license": "UNLICENSED",
    "homepage": "https://subscriptonarc.com",
    "repository": {
        "type": "git",
        "url": "https://github.com/KristienOWeb3/SubScript.git"
    },
    "engines": {
        "node": ">=22"
    },
    "workspaces": [
        "mcp-server",
        "packages/*"
    ],
    "overrides": {
        "form-data": "4.0.6",
        "hono": "4.12.27",
        "underscore": "1.13.8",
        "undici": "6.27.0",
        "ws": "8.21.0"
    },
    "scripts": {
        "dev": "next dev",
        "build": "prisma generate && node scripts/apply-migrations.mjs && next build",
        "db:migrate": "node scripts/apply-migrations.mjs",
        "build:cli": "npm run build --workspace @subscriptonarc/cli",
        "build:sdk": "npm run build --workspace @subscriptonarc/sdk",
        "start": "next start",
        "check:contracts": "node scripts/check-contracts.mjs",
        "integration:smoke": "node scripts/subscript-integration-smoke.mjs",
        "test:live-surface": "node scripts/test-live-surface.cjs",
        "test:docs": "node --test src/app/docs/__tests__/docs-quality.test.mjs",
        "test:repo-docs": "node --test src/app/docs/__tests__/repo-docs-structure.test.mjs",
        "test:push": "node --test src/lib/__tests__/push-notifications.test.mjs",
        "test:security": "node --test \"src/lib/ops/__tests__/*.test.mjs\" \"src/lib/sponsor/__tests__/*.test.mjs\" \"src/lib/subscriptions/__tests__/*.test.mjs\"",
        "audit:production": "npm audit --omit=dev --audit-level=high",
        "test:kyc": "node --test src/lib/kyc/__tests__/kyc.test.mjs",
        "test:contracts": "hardhat test",
        "typecheck": "tsc --noEmit",
        "load:test": "node scripts/load-test.mjs",
        "lint": "next lint"
    },
    "dependencies": {
        "@circle-fin/developer-controlled-wallets": "^10.8.0",
        "@circle-fin/w3s-pw-web-sdk": "^1.1.11",
        "@openzeppelin/contracts-upgradeable": "^5.6.1",
        "@phosphor-icons/react": "^2.1.10",
        "@prisma/client": "^6.19.3",
        "@sentry/nextjs": "^10.55.0",
        "@supabase/ssr": "^0.10.3",
        "@supabase/supabase-js": "^2.106.2",
        "@tanstack/react-query": "^5.100.14",
        "@types/web-push": "^3.6.4",
        "@upstash/ratelimit": "^2.0.8",
        "@upstash/redis": "^1.38.0",
        "circomlibjs": "^0.1.7",
        "cookies-next": "^6.1.1",
        "ethers": "^6.16.0",
        "framer-motion": "^11.15.0",
        "gsap": "^3.15.0",
        "jsqr": "^1.4.0",
        "lucide-react": "^0.469.0",
        "next": "^15.1.6",
        "pg": "^8.21.0",
        "posthog-js": "^1.376.5",
        "qrcode.react": "^4.2.0",
        "react": "^19.0.0",
        "react-dom": "^19.0.0",
        "react-qrcode-logo": "^4.1.0",
        "resend": "^6.14.0",
        "snarkjs": "^0.7.6",
        "three": "^0.184.0",
        "viem": "^2.51.3",
        "wagmi": "^2.19.5",
        "web-push": "^3.6.7"
    },
    "devDependencies": {
        "@nomicfoundation/hardhat-chai-matchers": "^2.1.2",
        "@nomicfoundation/hardhat-ethers": "^3.1.3",
        "@nomicfoundation/hardhat-network-helpers": "^1.0.12",
        "@nomicfoundation/hardhat-toolbox": "^5.0.0",
        "@nomicfoundation/hardhat-verify": "^3.0.18",
        "@openzeppelin/contracts": "^5.6.1",
        "@openzeppelin/hardhat-upgrades": "^4.0.1",
        "@playwright/test": "^1.49.0",
        "@privy-io/react-auth": "^3.6.1",
        "@typechain/ethers-v6": "^0.4.3",
        "@typechain/hardhat": "^7.0.0",
        "@types/chai": "^4.3.20",
        "@types/mocha": "^10.0.10",
        "@types/node": "^20",
        "@types/react": "^19",
        "@types/react-dom": "^19",
        "@types/three": "^0.184.1",
        "autoprefixer": "^10.4.23",
        "chai": "^4.5.0",
        "dotenv": "^17.4.2",
        "eslint": "^8",
        "eslint-config-next": "15.1.6",
        "hardhat": "^2.28.6",
        "hardhat-gas-reporter": "^1.0.10",
        "postcss": "^8",
        "prisma": "^6.19.3",
        "solidity-coverage": "^0.7.22",
        "tailwindcss": "^3.4.1",
        "ts-node": "^10.9.2",
        "typechain": "^8.3.2",
        "typescript": "^5"
    }
}
