datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model WaitlistLead {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email         String   @unique
  userType      String?  @map("user_type")
  walletAddress String?  @unique @map("wallet_address")
  companyName   String?  @map("company_name")
  useCase       String?  @map("use_case")
  monthlyVolume String?  @map("monthly_volume")
  createdAt     DateTime @default(now()) @map("created_at")

  @@map("waitlist_leads")
}

model ApiKey {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  walletAddress  String   @map("wallet_address")
  publishableKey String   @unique @map("publishable_key")
  secretKeyPlain String?  @map("secret_key_plain")
  secretKeyHash  String?  @unique @map("secret_key_hash")
  secretKeyHint  String?  @map("secret_key_hint")
  createdAt      DateTime @default(now()) @map("created_at")
  revoked        Boolean  @default(false)

  @@index([walletAddress])
  @@map("api_keys")
}

model WebhookEndpoint {
  id            String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  walletAddress String         @map("wallet_address")
  url           String
  secret        String
  active        Boolean        @default(true)
  createdAt     DateTime       @default(now()) @map("created_at")
  events        WebhookEvent[]

  @@index([walletAddress])
  @@map("webhook_endpoints")
}

model WebhookEvent {
  id                String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  webhookEndpointId String?          @map("webhook_endpoint_id") @db.Uuid
  endpoint          WebhookEndpoint? @relation(fields: [webhookEndpointId], references: [id], onDelete: Cascade)
  event             String?
  status            Int?
  payload           Json
  responseBody      String?          @map("response_body")
  txHash            String?          @unique @map("tx_hash")
  eventType         String?          @map("event_type")
  createdAt         DateTime         @default(now()) @map("created_at")

  @@index([webhookEndpointId])
  @@map("webhook_events")
}

model Session {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  wallet    String
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([wallet])
  @@map("sessions")
}

model PaymentLink {
  id                   String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  merchantAddress      String               @map("merchant_address")
  title                String
  description          String?
  amountUsdc           BigInt               @map("amount_usdc")
  active               Boolean              @default(true)
  expiresAt            DateTime?            @map("expires_at")
  externalReference    String?              @map("external_reference")
  receiptToken         String?              @unique @map("receipt_token")
  idempotencyKey       String?              @unique @map("idempotency_key")
  merchantNameSnapshot String?              @map("merchant_name_snapshot")
  maxUses              Int?                 @map("max_uses")
  useCount             Int                  @default(0) @map("use_count")
  beneficiaryAddress   String?              @map("beneficiary_address")
  // Invoice engine v1: these ride the existing link/receipt/webhook lifecycle.
  invoiceNumber        String?              @map("invoice_number")
  dueDate              DateTime?            @map("due_date")
  payerEmail           String?              @map("payer_email")
  receiverAddress      String?              @map("receiver_address")
  receiverPrivateKey   String?              @map("receiver_private_key")
  status               String               @default("PENDING") @map("status")
  paidAt               DateTime?            @map("paid_at")
  verifiedTxHash       String?              @map("verified_tx_hash")
  settlementReference  String?              @map("settlement_reference")
  stateSnapshot        Json?                @map("state_snapshot")
  createdAt            DateTime             @default(now()) @map("created_at")
  updatedAt            DateTime             @default(now()) @map("updated_at")
  payments             PaymentLinkPayment[]

  @@index([merchantAddress], map: "payment_links_merchant_idx")
  @@index([active], map: "payment_links_active_idx")
  @@index([beneficiaryAddress], map: "payment_links_beneficiary_address_idx")
  @@map("payment_links")
}

model PaymentLinkPayment {
  id                  String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  paymentLinkId       String      @map("payment_link_id") @db.Uuid
  paymentLink         PaymentLink @relation(fields: [paymentLinkId], references: [id], onDelete: Cascade)
  payerAddress        String      @map("payer_address")
  beneficiaryAddress  String?     @map("beneficiary_address")
  amountUsdc          BigInt      @map("amount_usdc")
  txHash              String      @unique @map("tx_hash")
  merchantAddress     String      @map("merchant_address")
  credited            Boolean     @default(false)
  creditedAt          DateTime?   @map("credited_at")
  verificationBlock   BigInt?     @map("verification_block")
  verificationChainId BigInt?     @map("verification_chain_id")
  createdAt           DateTime    @default(now()) @map("created_at")
  updatedAt           DateTime    @default(now()) @map("updated_at")

  @@index([paymentLinkId])
  @@index([txHash])
  @@index([merchantAddress])
  @@index([beneficiaryAddress], map: "payment_link_payments_beneficiary_address_idx")
  @@map("payment_link_payments")
}

model Merchant {
  walletAddress           String           @id @map("wallet_address")
  tier                    String           @default("FREE") @map("tier")
  payoutDestination       String?          @map("payout_destination")
  availableBalanceUsdc    BigInt           @default(0) @map("available_balance_usdc")
  reservedBalanceUsdc     BigInt           @default(0) @map("reserved_balance_usdc")
  shieldedPayoutsEnabled  Boolean          @default(false) @map("shielded_payouts_enabled")
  viewKeyHash             String?          @map("view_key_hash")
  verified                Boolean          @default(false) @map("verified")
  profilePic              String?          @map("profile_pic")
  pushEnabled             Boolean          @default(true) @map("push_enabled")
  emailEnabled            Boolean          @default(true) @map("email_enabled")
  payoutSettlementEnabled Boolean          @default(true) @map("payout_settlement_enabled")
  disputeAlertsEnabled    Boolean          @default(true) @map("dispute_alerts_enabled")
  churnSurveyEnabled      Boolean          @default(true) @map("churn_survey_enabled")
  churnSurveyQuestion     String?          @map("churn_survey_question")
  // Failed renewal attempts before the keeper stops a customer subscription (zombie kill).
  dunningMaxFailures      Int              @default(4) @map("dunning_max_failures")
  securityMultiSigEnabled Boolean          @default(false) @map("security_multi_sig_enabled")
  createdAt               DateTime         @default(now()) @map("created_at")
  updatedAt               DateTime         @default(now()) @updatedAt @map("updated_at")
  subscriptions           Subscription[]
  paymentSessions         PaymentSession[]
  meteredVaults           MeteredVault[]

  @@map("merchants")
}

model MerchantPlan {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  merchantAddress String   @map("merchant_address")
  name            String
  description     String?
  detailsUrl      String?  @map("details_url")
  amountUsdc      BigInt   @map("amount_usdc")
  periodSeconds   BigInt   @map("period_seconds")
  // Minimum commitment disclosed before subscribing; capped at one billing period and 30 days.
  minCommitmentSeconds BigInt @default(0) @map("min_commitment_seconds")
  active          Boolean  @default(true)
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @default(now()) @updatedAt @map("updated_at")

  @@index([merchantAddress])
  @@map("merchant_plans")
}

model Subscription {
  subscriptionId          BigInt    @id @map("subscription_id")
  merchantAddress         String    @map("merchant_address")
  merchant                Merchant  @relation(fields: [merchantAddress], references: [walletAddress], onDelete: Cascade)
  currentNonce            Int       @default(0) @map("current_nonce")
  lastSettlementTimestamp DateTime? @map("last_settlement_timestamp")
  nextBillingDate         DateTime? @map("next_billing_date")
  billingIntervalSeconds  BigInt    @map("billing_interval_seconds")
  amountCapUsdc           Decimal   @map("amount_cap_usdc")
  paymentTxHash           String?   @unique @map("payment_tx_hash")
  status                  String    @default("PENDING") @map("status")
  tier                    Int       @default(0) @map("tier")
  subscriber              String?   @map("subscriber")
  cancelAtPeriodEnd       Boolean   @default(false) @map("cancel_at_period_end")
  cancelRequestedAt       DateTime? @map("cancel_requested_at")
  downgradeFailures       Int       @default(0) @map("downgrade_failures")
  // "PREMIUM" (merchant -> SubScript, billed by the in-app cron) or "CUSTOMER"
  // (customer -> merchant plan, billed on-chain). See subscriptions/mirror.ts.
  kind                    String    @default("PREMIUM") @map("kind")
  // Sponsored subscriptions: the wallet that receives the service when it differs from
  // the paying subscriber. Carried in merchant webhooks for entitlement mapping.
  beneficiaryAddress      String?   @map("beneficiary_address")
  // Snapshot of the plan's commitment window at subscribe time (<= one period by constraint).
  minCommitmentUntil      DateTime? @map("min_commitment_until")
  createdAt               DateTime  @default(now()) @map("created_at")
  updatedAt               DateTime  @default(now()) @map("updated_at")

  @@index([merchantAddress])
  @@index([subscriber])
  @@index([beneficiaryAddress])
  @@map("subscriptions")
}

model PaymentSession {
  sessionId           String    @id @default(dbgenerated("gen_random_uuid()")) @map("session_id") @db.Uuid
  merchantAddress     String    @map("merchant_address")
  merchant            Merchant  @relation(fields: [merchantAddress], references: [walletAddress], onDelete: Cascade)
  txHash              String?   @unique @map("tx_hash")
  amountExpected      BigInt    @default(10000000) @map("amount_expected")
  chainId             Int       @default(5042002) @map("chain_id")
  status              String    @default("PENDING") @map("status")
  processingBy        String?   @map("processing_by")
  processingStartedAt DateTime? @map("processing_started_at")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @default(now()) @map("updated_at")
  expiresAt           DateTime? @map("expires_at")

  @@index([merchantAddress])
  @@index([txHash])
  @@index([status])
  @@map("payment_sessions")
}

model PayoutBatch {
  id              String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  merchantAddress String             @map("merchant_address")
  status          String
  recipientCount  Int                @map("recipient_count")
  totalAmountUsdc BigInt             @map("total_amount_usdc")
  txHash          String?            @map("tx_hash")
  createdAt       DateTime           @default(now()) @map("created_at")
  updatedAt       DateTime           @default(now()) @map("updated_at")
  chunks          PayoutBatchChunk[]
  items           PayoutBatchItem[]

  @@index([merchantAddress])
  @@index([status])
  @@map("payout_batches")
}

model PayoutBatchChunk {
  id             String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  batchId        String            @map("batch_id") @db.Uuid
  batch          PayoutBatch       @relation(fields: [batchId], references: [id], onDelete: Cascade)
  chunkIndex     Int               @map("chunk_index")
  status         String
  txHash         String?           @map("tx_hash")
  recipientCount Int               @map("recipient_count")
  totalAmount    BigInt            @map("total_amount")
  createdAt      DateTime          @default(now()) @map("created_at")
  updatedAt      DateTime          @default(now()) @map("updated_at")
  items          PayoutBatchItem[]

  @@index([batchId])
  @@map("payout_batch_chunks")
}

model PayoutBatchItem {
  id               String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  batchId          String            @map("batch_id") @db.Uuid
  batch            PayoutBatch       @relation(fields: [batchId], references: [id], onDelete: Cascade)
  chunkId          String?           @map("chunk_id") @db.Uuid
  chunk            PayoutBatchChunk? @relation(fields: [chunkId], references: [id], onDelete: SetNull)
  recipientAddress String            @map("recipient_address")
  amountUsdc       BigInt            @map("amount_usdc")
  status           String
  txHash           String?           @map("tx_hash")
  createdAt        DateTime          @default(now()) @map("created_at")

  @@index([batchId])
  @@index([recipientAddress])
  @@index([status])
  @@map("payout_batch_items")
}

model IdempotencyKey {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  executionKey    String   @unique @map("execution_key")
  status          String
  responsePayload Json?    @map("response_payload")
  expiresAt       DateTime @map("expires_at")
  lastAccessedAt  DateTime @default(now()) @map("last_accessed_at")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @default(now()) @map("updated_at")

  @@index([executionKey])
  @@index([expiresAt])
  @@map("idempotency_keys")
}

model LedgerEntry {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  merchantAddress Bytes    @map("merchant_address")
  entryType       String   @map("entry_type")
  status          String   @default("PENDING")
  amountUsdc      BigInt   @map("amount_usdc")
  referenceType   String   @map("reference_type")
  referenceId     String   @map("reference_id")
  txHash          String?  @map("tx_hash")
  createdAt       DateTime @default(now()) @map("created_at")

  @@index([merchantAddress])
  @@map("ledger_entries")
}

model EventLog {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  eventId        String   @unique @map("event_id") @db.Uuid
  entityId       String   @map("entity_id")
  entityType     String   @map("entity_type")
  eventType      String   @map("event_type")
  correlationId  String   @map("correlation_id")
  sequenceNumber BigInt   @map("sequence_number")
  payload        Json
  createdAt      DateTime @default(now()) @map("created_at")

  @@index([entityType, entityId], map: "event_log_entity_idx")
  @@index([entityId, sequenceNumber], map: "event_log_sequence_idx")
  @@map("event_log")
}

model SystemSnapshot {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  entityId       String   @map("entity_id")
  entityType     String   @map("entity_type")
  sequenceOffset BigInt   @map("sequence_offset")
  statePayload   Json     @map("state_payload")
  createdAt      DateTime @default(now()) @map("created_at")

  @@index([entityType, entityId], map: "system_snapshots_entity_idx")
  @@map("system_snapshots")
}

model TransactionVerification {
  txHash        String   @id @map("tx_hash")
  status        String
  referenceType String   @map("reference_type")
  referenceId   String   @map("reference_id")
  confirmations Int      @default(0)
  errorMessage  String?  @map("error_message")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @default(now()) @map("updated_at")

  @@index([status], map: "transaction_verifications_status_idx")
  @@map("transaction_verifications")
}

model WebhookDelivery {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  webhookEndpointId String   @map("webhook_endpoint_id") @db.Uuid
  eventId           String?  @map("event_id")
  event             String
  status            String
  payload           Json
  signatureVersion  String   @default("v1") @map("signature_version")
  attempts          Int      @default(0)
  lastError         String?  @map("last_error")
  responseBody      String?  @map("response_body")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @default(now()) @map("updated_at")

  @@index([webhookEndpointId])
  @@index([status])
  @@unique([webhookEndpointId, eventId], map: "webhook_deliveries_endpoint_event_unique")
  @@map("webhook_deliveries")
}

model AuditEvent {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  actor        String
  action       String
  resourceType String   @map("resource_type")
  resourceId   String   @map("resource_id")
  ipAddress    String?  @map("ip_address")
  metadata     Json?
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([actor])
  @@index([action])
  @@map("audit_events")
}

model Customer {
  walletAddress           String         @id @map("wallet_address")
  email                   String?
  profilePic              String?        @map("profile_pic")
  spendingLimitDaily      BigInt?        @map("spending_limit_daily")
  spendingLimitWeekly     BigInt?        @map("spending_limit_weekly")
  spendingLimitMonthly    BigInt?        @map("spending_limit_monthly")
  pushEnabled             Boolean        @default(true) @map("push_enabled")
  emailEnabled            Boolean        @default(true) @map("email_enabled")
  debitSuccessEnabled     Boolean        @default(true) @map("debit_success_enabled")
  expiryWarningEnabled    Boolean        @default(true) @map("expiry_warning_enabled")
  securityShieldEnabled   Boolean        @default(false) @map("security_shield_enabled")
  securityMultiSigEnabled Boolean        @default(false) @map("security_multi_sig_enabled")
  createdAt               DateTime       @default(now()) @map("created_at")
  meteredVaults           MeteredVault[]

  @@map("customers")
}

model UserEmbeddedWallet {
  id                  String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email               String    @unique
  walletAddress       String    @unique @map("wallet_address")
  encryptedPrivateKey String?   @map("encrypted_private_key")
  provider            String    @default("circle_google")
  circleWalletId      String?   @unique @map("circle_wallet_id")
  circleUserId        String?   @map("circle_user_id")
  circleBlockchain    String?   @map("circle_blockchain")
  googleSubject       String?   @map("google_subject")
  backupCompletedAt   DateTime? @map("backup_completed_at")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @default(now()) @updatedAt @map("updated_at")

  @@map("user_embedded_wallets")
}

model Receipt {
  receiptId            String    @id @map("receipt_id")
  paymentLinkId        String?   @map("payment_link_id") @db.Uuid
  paymentLinkPaymentId String?   @map("payment_link_payment_id") @db.Uuid
  txHash               String    @unique @map("tx_hash")
  chainId              Int       @map("chain_id")
  memoContract         String    @map("memo_contract")
  payerAddress         String    @map("payer_address")
  beneficiaryAddress   String?   @map("beneficiary_address")
  merchantAddress      String    @map("merchant_address")
  amountUsdc           BigInt    @map("amount_usdc")
  memoNote             String?   @map("memo_note")
  shareUrl             String    @map("share_url")
  status               String    @default("PENDING")
  blockNumber          BigInt?   @map("block_number")
  logIndex             Int?      @map("log_index")
  confirmedAt          DateTime? @map("confirmed_at")
  invitedAddresses     String    @default("") @map("invited_addresses")
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @default(now()) @updatedAt @map("updated_at")

  @@index([payerAddress])
  @@index([beneficiaryAddress], map: "receipts_beneficiary_address_idx")
  @@index([merchantAddress])
  @@index([status])
  @@index([paymentLinkId])
  @@map("receipts")
}

model MerchantEmailTemplate {
  merchantAddress String  @id @map("merchant_address")
  isActive        Boolean @default(false) @map("is_active")
  subjectLine     String  @map("subject_line")
  bodyContent     String  @map("body_content")

  @@map("merchant_email_templates")
}

enum PayrollStatus {
  ACTIVE
  PAUSED
}

model PayrollCampaign {
  id                  String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationAddress String             @map("organization_address")
  title               String
  frequencyDays       Int                @map("frequency_days")
  nextPayday          DateTime           @map("next_payday")
  isShielded          Boolean            @map("is_shielded")
  status              PayrollStatus      @default(ACTIVE)
  permit2Signature    String?            @map("permit2_signature")
  permit2Nonce        Int?               @map("permit2_nonce")
  permit2Deadline     DateTime?          @map("permit2_deadline")
  permit2Expiration   DateTime?          @map("permit2_expiration")
  recipients          PayrollRecipient[]

  @@index([organizationAddress])
  @@index([status])
  @@map("payroll_campaigns")
}

model PayrollRecipient {
  id               String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  campaignId       String          @map("campaign_id") @db.Uuid
  campaign         PayrollCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  employeeWallet   String          @map("employee_wallet")
  salaryAmountUsdc BigInt          @map("salary_amount_usdc")

  @@index([campaignId])
  @@map("payroll_recipients")
}
model AddressAlias {
  address       String    @id @map("address")
  alias         String    @unique @map("alias")
  isAnonymous   Boolean   @default(false) @map("is_anonymous")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @default(now()) @updatedAt @map("updated_at")
  // Last time the wallet *changed* its alias value. NULL for the auto-assigned
  // default username, so the first user-initiated change is free; subsequent
  // changes are rate-limited to once every 365 days. See merchant/alias route.
  lastChangedAt DateTime? @map("last_changed_at")

  @@map("address_aliases")
}

model AccountRole {
  address   String   @id @map("address")
  role      String   // "USER" or "ENTERPRISE"
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")
  kycVerification KycVerification?

  @@map("account_roles")
}

model KycVerification {
  id                String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  walletAddress     String                 @unique @map("wallet_address")
  accountRole       String                 @map("account_role")
  kind              String
  countryCode       String                 @map("country_code")
  provider          String
  providerCaseId    String?                @unique @map("provider_case_id")
  requestedLevel    String                 @default("STANDARD") @map("requested_level")
  status            String                 @default("PENDING")
  reasonCode        String?                @map("reason_code")
  consentVersion    String                 @map("consent_version")
  consentedAt       DateTime               @map("consented_at")
  submittedAt       DateTime?              @map("submitted_at")
  providerUpdatedAt DateTime?              @map("provider_updated_at")
  decidedAt         DateTime?              @map("decided_at")
  expiresAt         DateTime?              @map("expires_at")
  createdAt         DateTime               @default(now()) @map("created_at")
  updatedAt         DateTime               @default(now()) @updatedAt @map("updated_at")
  revision          Int                    @default(1)
  account           AccountRole            @relation(fields: [walletAddress], references: [address], onDelete: Restrict)
  events            KycVerificationEvent[]

  @@index([status, createdAt(sort: Desc)], map: "kyc_verifications_review_queue_idx")
  @@map("kyc_verifications")
}

model KycVerificationEvent {
  id              String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  verificationId  String          @map("verification_id") @db.Uuid
  providerEventId String?         @unique @map("provider_event_id")
  actorType       String          @map("actor_type")
  actorId         String?         @map("actor_id")
  fromStatus      String?         @map("from_status")
  toStatus        String          @map("to_status")
  reasonCode      String?         @map("reason_code")
  createdAt       DateTime        @default(now()) @map("created_at")
  verification    KycVerification @relation(fields: [verificationId], references: [id], onDelete: Restrict)

  @@index([verificationId, createdAt(sort: Desc)], map: "kyc_verification_events_verification_created_idx")
  @@map("kyc_verification_events")
}

model SubscriptDm {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  senderAddress   String   @map("sender_address")
  receiverAddress String   @map("receiver_address")
  messageType     String   @map("message_type") // payment, receipt, subscription, and commit lifecycle messages
  status          String   @default("PENDING")  // "PENDING", "APPROVED", "DECLINED", "DISMISSED"
  amountUsdc      BigInt?  @map("amount_usdc")
  title           String?
  description     String?
  txHash          String?  @map("tx_hash")
  paymentLinkId   String?  @map("payment_link_id") @db.Uuid
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @default(now()) @updatedAt @map("updated_at")

  @@index([senderAddress])
  @@index([receiverAddress])
  @@map("subscript_dms")
}

model MeteredVault {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userAddress       String   @map("user_address")
  merchantAddress   String   @map("merchant_address")
  balanceUsdc       BigInt   @default(0) @map("balance_usdc")
  thresholdUsdc     BigInt   @default(2000000) @map("threshold_usdc")
  topUpAmountUsdc   BigInt   @default(10000000) @map("top_up_amount_usdc")
  monthlyLimitUsdc  BigInt   @default(50000000) @map("monthly_limit_usdc")
  monthlySpentUsdc  BigInt   @default(0) @map("monthly_spent_usdc")
  lastTopUpAt       DateTime? @map("last_top_up_at")

  // On-chain escrow mirror (dormant until SubScriptVault is deployed + routes cut over).
  commitUsdc        BigInt   @default(0) @map("commit_usdc")
  owedUsdc          BigInt   @default(0) @map("owed_usdc")
  accruedUsageUsdc  BigInt   @default(0) @map("accrued_usage_usdc")
  cycleStart        DateTime? @map("cycle_start")
  lockedUntil       DateTime? @map("locked_until")
  active            Boolean  @default(false)
  vaultChainId      Int?     @map("vault_chain_id")
  lastSyncedBlock   BigInt?  @map("last_synced_block")

  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @default(now()) @updatedAt @map("updated_at")

  merchant          Merchant @relation(fields: [merchantAddress], references: [walletAddress], onDelete: Cascade)
  customer          Customer @relation(fields: [userAddress], references: [walletAddress], onDelete: Cascade)

  @@unique([userAddress, merchantAddress])
  @@index([userAddress])
  @@index([merchantAddress])
  @@map("metered_vaults")
}

model TestClock {
  id              String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  merchantAddress String                  @map("merchant_address")
  name            String                  @default("test clock")
  frozenTime      DateTime                @default(now()) @map("frozen_time")
  createdAt       DateTime                @default(now()) @map("created_at")
  subscriptions   TestClockSubscription[]

  @@index([merchantAddress])
  @@map("test_clocks")
}

model TestClockSubscription {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clockId          String    @map("clock_id") @db.Uuid
  clock            TestClock @relation(fields: [clockId], references: [id], onDelete: Cascade)
  name             String    @default("test subscription")
  amountUsdcMicros BigInt    @map("amount_usdc_micros")
  intervalSeconds  BigInt    @map("interval_seconds")
  subscriberLabel  String    @default("0x0000000000000000000000000000000000000t35") @map("subscriber_label")
  startedAt        DateTime  @default(now()) @map("started_at")
  lastRenewedAt    DateTime? @map("last_renewed_at")
  renewalsFired    Int       @default(0) @map("renewals_fired")
  createdAt        DateTime  @default(now()) @map("created_at")

  @@index([clockId])
  @@map("test_clock_subscriptions")
}

model FiatFundingIntent {
  id                          String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  walletAddress               String             @map("wallet_address")
  destinationWallet           String             @map("destination_wallet")
  idempotencyKey              String             @map("idempotency_key")
  provider                    String             @default("SUBSCRIPT_SANDBOX")
  providerReference           String             @unique @map("provider_reference")
  fiatCurrency                String             @default("NGN") @map("fiat_currency")
  fiatAmountMinor             BigInt             @map("fiat_amount_minor")
  quoteRateNgnPerUsdcMinor    BigInt             @map("quote_rate_ngn_per_usdc_minor")
  grossUsdcMicros             BigInt             @map("gross_usdc_micros")
  feeFiatMinor                BigInt             @default(0) @map("fee_fiat_minor")
  netUsdcMicros               BigInt             @map("net_usdc_micros")
  status                      String             @default("AWAITING_TRANSFER")
  bankName                    String             @map("bank_name")
  accountName                 String             @map("account_name")
  accountNumber               String             @map("account_number")
  transferReference           String             @unique @map("transfer_reference")
  destinationChainId          Int                @map("destination_chain_id")
  settlementTxHash            String?            @unique @map("settlement_tx_hash")
  expiresAt                   DateTime           @map("expires_at")
  receivedAt                  DateTime?           @map("received_at")
  settledAt                   DateTime?           @map("settled_at")
  createdAt                   DateTime           @default(now()) @map("created_at")
  updatedAt                   DateTime           @default(now()) @updatedAt @map("updated_at")
  events                      FiatFundingEvent[]

  @@unique([walletAddress, idempotencyKey], map: "fiat_funding_intents_wallet_idempotency_key")
  @@index([walletAddress, createdAt], map: "fiat_funding_intents_owner_created_idx")
  @@index([walletAddress, status], map: "fiat_funding_intents_owner_status_idx")
  @@index([provider, providerReference], map: "fiat_funding_intents_provider_reference_idx")
  @@map("fiat_funding_intents")
}

model FiatFundingEvent {
  id                String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  fundingIntentId   String            @map("funding_intent_id") @db.Uuid
  fundingIntent     FiatFundingIntent @relation(fields: [fundingIntentId], references: [id], onDelete: Restrict)
  providerEventId   String            @unique @map("provider_event_id")
  eventType         String            @map("event_type")
  payload           Json
  processingResult  String?           @map("processing_result")
  processingError   String?           @map("processing_error")
  processedAt       DateTime?         @map("processed_at")
  createdAt         DateTime          @default(now()) @map("created_at")
  updatedAt         DateTime          @default(now()) @updatedAt @map("updated_at")

  @@index([fundingIntentId, createdAt], map: "fiat_funding_events_intent_created_idx")
  @@map("fiat_funding_events")
}

model Referral {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  referrerAddress String   @map("referrer_address")
  referredAddress String   @unique @map("referred_address")
  status          String   @default("REGISTERED") // REGISTERED, ACTIVE, COMPLETED
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @default(now()) @updatedAt @map("updated_at")

  @@index([referrerAddress])
  @@map("referrals")
}
