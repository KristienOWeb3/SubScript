datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model WaitlistLead {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email         String   @unique
  userType      String?  @map("user_type")
  companyName   String?  @map("company_name")
  useCase       String?  @map("use_case")
  monthlyVolume String?  @map("monthly_volume")
  createdAt     DateTime @default(now()) @map("created_at")

  @@map("waitlist_leads")
}

model ApiKey {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  walletAddress  String   @map("wallet_address")
  publishableKey String   @unique @map("publishable_key")
  secretKeyPlain String   @map("secret_key_plain")
  createdAt      DateTime @default(now()) @map("created_at")
  revoked        Boolean  @default(false)

  @@index([walletAddress])
  @@map("api_keys")
}

model WebhookEndpoint {
  id            String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  walletAddress String         @map("wallet_address")
  url           String
  secret        String
  active        Boolean        @default(true)
  createdAt     DateTime       @default(now()) @map("created_at")
  events        WebhookEvent[]

  @@index([walletAddress])
  @@map("webhook_endpoints")
}

model WebhookEvent {
  id                String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  webhookEndpointId String          @map("webhook_endpoint_id") @db.Uuid
  endpoint          WebhookEndpoint @relation(fields: [webhookEndpointId], references: [id], onDelete: Cascade)
  event             String
  status            Int
  payload           Json
  responseBody      String?         @map("response_body")
  createdAt         DateTime        @default(now()) @map("created_at")

  @@index([webhookEndpointId])
  @@map("webhook_events")
}

model Session {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  wallet    String
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([wallet])
  @@map("sessions")
}

